<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <WebView
        android:id="@+id/youtubeWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/speedBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#CC000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/modeSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="#99000000">

        <Button
            android:id="@+id/modeGentle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/mode_button_bg"
            android:text="1.1x Suave"
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp" />

        <Button
            android:id="@+id/modeBalanced"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/mode_button_bg"
            android:text="1.25x Equil."
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp" />

        <Button
            android:id="@+id/modeAggressive"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/mode_button_bg"
            android:text="1.5x Agress."
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp" />

    </LinearLayout>

</FrameLayout>
